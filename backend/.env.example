# ============================================
# Brain AGI Platform — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# See .env (your local copy) for the actual secrets.

# --- App ---
APP_NAME=BrainAGI
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string

# --- Database ---
# PostgreSQL (required — pgvector extension must be enabled):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/brain_agi
# DATABASE_URL_SYNC=postgresql://user:***@host:5432/brain_agi

# --- Redis (Upstash or local) ---
# REDIS_URL=rediss://default:password@your-upstash-host.upstash.io:6379

# --- Supabase (optional, for auth integration) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key

# --- OpenRouter (required for AI chat) ---
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Free models for development — swap for paid models in production
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_REASONING_MODEL=nousresearch/hermes-3-llama-3.1-405b:free
OPENROUTER_AGENT_MODEL=google/gemma-4-26b-a4b-it:free

# --- Auth ---
JWT_SECRET=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=72

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- Celery (background tasks) ---
CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=rediss://default:password@your-upstash-host.upstash.io:6379
