# ============================================
# Brain AGI Platform — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# --- App ---
APP_NAME=BrainAGI
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string

# --- Database ---
# SQLite (default, for local development):
DATABASE_URL=sqlite+aiosqlite:///./brain_agi.db
DATABASE_URL_SYNC=sqlite:///./brain_agi.db
# PostgreSQL (recommended for production with pgvector):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/brain_agi
# DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/brain_agi

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Supabase (optional) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key

# --- OpenRouter (required for AI features) ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_REASONING_MODEL=anthropic/claude-sonnet-4
OPENROUTER_AGENT_MODEL=openai/gpt-4o

# --- Auth ---
JWT_SECRET=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=72

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- Celery (optional, for background tasks) ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
